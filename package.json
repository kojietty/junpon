{
  "name": "jungle-pang-clone",
  "version": "0.1.0",
  "private": true,
  "description": "JUNGLE PANG-style color sorting tap action game (HTML5 / Phaser 3)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
